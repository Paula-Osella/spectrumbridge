---
---
<section
  class="relative min-h-screen flex items-center pt-20 overflow-hidden bg-gradient-to-br from-mist-50 via-white to-sage-50 noise"
  aria-labelledby="hero-heading"
>
  <!-- Background blobs -->
  <div class="blob w-96 h-96 bg-sage-200 top-10 -left-24" aria-hidden="true"></div>
  <div class="blob w-80 h-80 bg-sky-100 bottom-20 right-0" aria-hidden="true"></div>
  <div class="blob w-64 h-64 bg-sand-100 top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2" aria-hidden="true"></div>

  <div class="relative max-w-7xl mx-auto px-6 lg:px-12 py-24 lg:py-32 grid lg:grid-cols-2 gap-16 lg:gap-24 items-center">

    <!-- Text content -->
    <div class="max-w-2xl">
      <div class="section-label" data-aos="fade-down" data-aos-delay="100">
        Inclusive Integration Platform
      </div>

      <h1
        id="hero-heading"
        class="font-display text-5xl md:text-6xl lg:text-7xl font-light text-mist-900 leading-[1.1] mb-6"
        data-aos="fade-up"
        data-aos-delay="150"
      >
        A place where
        <span class="italic text-sage-500"> every mind</span>
        <br/>finds its bridge.
      </h1>

      <p
        class="text-lg md:text-xl text-mist-600 leading-relaxed max-w-lg mb-10"
        data-aos="fade-up"
        data-aos-delay="220"
      >
        SpectrumBridge helps autistic individuals, families, and organizations
        connect with the right resources, people, and environments — 
        at their own pace, in their own way.
      </p>

      <div
        class="flex flex-col sm:flex-row gap-4"
        data-aos="fade-up"
        data-aos-delay="300"
      >
        <a href="#contact" class="btn-primary">
          Start Your Journey
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
        <a href="#how-it-works" class="btn-secondary">
          See How It Works
        </a>
      </div>

      <!-- Trust bar -->
      <div
        class="mt-16 flex items-center gap-6 flex-wrap"
        data-aos="fade-up"
        data-aos-delay="380"
        aria-label="Trust indicators"
      >
        <div class="flex items-center gap-2 text-sm text-mist-500">
          <svg class="w-4 h-4 text-sage-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
          </svg>
          <span>Free to start</span>
        </div>
        <div class="flex items-center gap-2 text-sm text-mist-500">
          <svg class="w-4 h-4 text-sage-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
          </svg>
          <span>No pressure onboarding</span>
        </div>
        <div class="flex items-center gap-2 text-sm text-mist-500">
          <svg class="w-4 h-4 text-sage-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
          </svg>
          <span>Built with autistic advisors</span>
        </div>
      </div>
    </div>

    <!-- Hero image -->
    <div class="relative" data-aos="fade-left" data-aos-delay="200">
      <div class="relative rounded-4xl overflow-hidden shadow-soft-lg">
        <img
          src="https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?w=800&q=80&auto=format&fit=crop"
          alt="A person calmly working in a comfortable, naturally lit space"
          class="w-full h-[480px] object-cover"
          width="800"
          height="480"
          loading="eager"
          decoding="async"
        />
        <!-- Soft gradient overlay -->
        <div class="absolute inset-0 bg-gradient-to-t from-sage-900/20 to-transparent" aria-hidden="true"></div>
      </div>

      <!-- Floating badge -->
      <div
        class="absolute -bottom-6 -left-6 bg-white rounded-2xl p-4 shadow-soft-lg border border-mist-100"
        aria-hidden="true"
      >
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-xl bg-sage-50 flex items-center justify-center">
            <svg class="w-5 h-5 text-sage-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
            </svg>
          </div>
          <div>
            <p class="text-xs text-mist-500 font-medium">People supported</p>
            <p class="text-lg font-display font-semibold text-mist-900">12,400+</p>
          </div>
        </div>
      </div>

      <!-- Second floating badge -->
      <div
        class="absolute -top-4 -right-4 bg-sage-500 text-white rounded-2xl p-4 shadow-soft-lg"
        aria-hidden="true"
      >
        <div class="text-center">
          <p class="text-2xl font-display font-light leading-none">98%</p>
          <p class="text-xs font-medium mt-1 opacity-90">Satisfaction</p>
        </div>
      </div>
    </div>

  </div>
</section>
