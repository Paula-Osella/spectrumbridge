---
const navLinks = [
  { label: 'About', href: '#about' },
  { label: 'How it Works', href: '#how-it-works' },
  { label: 'Benefits', href: '#benefits' },
  { label: 'Testimonials', href: '#testimonials' },
];
---
<header
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
  id="navbar"
  role="banner"
>
  <div class="max-w-7xl mx-auto px-6 lg:px-12">
    <nav
      class="flex items-center justify-between h-18 md:h-20"
      aria-label="Main navigation"
    >
      <!-- Logo -->
      <a
        href="#"
        class="flex items-center gap-3 group focus-visible:outline-none"
        aria-label="SpectrumBridge — home"
      >
        <div
          class="w-9 h-9 rounded-xl bg-sage-500 flex items-center justify-center
            group-hover:bg-sage-600 transition-colors duration-300 shadow-soft"
          aria-hidden="true"
        >
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="10" cy="10" r="3" fill="white" opacity="0.9"/>
            <path d="M10 3C10 3 4 6 4 10C4 14 10 17 10 17" stroke="white" stroke-width="1.5" stroke-linecap="round" opacity="0.7"/>
            <path d="M10 3C10 3 16 6 16 10C16 14 10 17 10 17" stroke="white" stroke-width="1.5" stroke-linecap="round" opacity="0.5"/>
          </svg>
        </div>
        <span class="font-display text-xl font-semibold text-mist-900 group-hover:text-sage-600 transition-colors duration-200">
          Spectrum<span class="text-sage-500">Bridge</span>
        </span>
      </a>

      <!-- Desktop nav -->
      <ul class="hidden md:flex items-center gap-1" role="list">
        {navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="px-4 py-2 rounded-full text-sm font-medium text-mist-600
                hover:text-sage-600 hover:bg-sage-50
                transition-all duration-200 focus-visible:ring-2 focus-visible:ring-sage-400"
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>

      <!-- CTA + hamburger -->
      <div class="flex items-center gap-3">
        <a
          href="#contact"
          class="hidden md:inline-flex btn-primary py-2.5 px-6 text-sm"
        >
          Get Started
        </a>

        <!-- Mobile menu button -->
        <button
          class="md:hidden p-2 rounded-xl text-mist-600 hover:bg-mist-100 transition-colors"
          id="menu-toggle"
          aria-expanded="false"
          aria-controls="mobile-menu"
          aria-label="Toggle mobile menu"
        >
          <svg id="icon-menu" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
          <svg id="icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
    </nav>

    <!-- Mobile menu -->
    <div
      id="mobile-menu"
      class="md:hidden hidden pb-6"
      role="navigation"
      aria-label="Mobile navigation"
    >
      <ul class="flex flex-col gap-1" role="list">
        {navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="block px-4 py-3 rounded-xl text-mist-700 hover:text-sage-600 hover:bg-sage-50
                font-medium transition-all duration-200"
            >
              {link.label}
            </a>
          </li>
        ))}
        <li class="mt-3">
          <a href="#contact" class="btn-primary w-full justify-center text-sm">
            Get Started
          </a>
        </li>
      </ul>
    </div>
  </div>
</header>

<script>
  const navbar = document.getElementById('navbar')!;
  const menuToggle = document.getElementById('menu-toggle')!;
  const mobileMenu = document.getElementById('mobile-menu')!;
  const iconMenu = document.getElementById('icon-menu')!;
  const iconClose = document.getElementById('icon-close')!;

  // Sticky style on scroll
  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      navbar.classList.add('bg-white/90', 'backdrop-blur-md', 'border-b', 'border-mist-100', 'shadow-sm');
    } else {
      navbar.classList.remove('bg-white/90', 'backdrop-blur-md', 'border-b', 'border-mist-100', 'shadow-sm');
    }
  }, { passive: true });

  // Mobile menu toggle
  menuToggle.addEventListener('click', () => {
    const isOpen = !mobileMenu.classList.contains('hidden');
    mobileMenu.classList.toggle('hidden');
    menuToggle.setAttribute('aria-expanded', String(!isOpen));
    iconMenu.classList.toggle('hidden');
    iconClose.classList.toggle('hidden');
    if (!isOpen) {
      navbar.classList.add('bg-white/95', 'backdrop-blur-md', 'shadow-sm');
    }
  });

  // Close mobile menu on link click
  mobileMenu.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu.classList.add('hidden');
      menuToggle.setAttribute('aria-expanded', 'false');
      iconMenu.classList.remove('hidden');
      iconClose.classList.add('hidden');
    });
  });
</script>
