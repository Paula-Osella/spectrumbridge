---
---
<section
  id="contact"
  class="py-24 lg:py-32 bg-white"
  aria-labelledby="cta-heading"
>
  <div class="max-w-7xl mx-auto px-6 lg:px-12">
    <div
      class="relative rounded-5xl overflow-hidden bg-sage-500 px-8 md:px-16 lg:px-24 py-20 lg:py-28 noise"
      data-aos="fade-up"
    >
      <!-- Background elements -->
      <div class="blob w-96 h-96 bg-sage-400 -top-20 -right-20 opacity-40" aria-hidden="true"></div>
      <div class="blob w-64 h-64 bg-sage-600 bottom-10 left-10 opacity-30" aria-hidden="true"></div>

      <div class="relative max-w-2xl mx-auto text-center">
        <div class="inline-flex items-center gap-2 text-sage-100 text-sm font-mono tracking-widest uppercase mb-6" data-aos="fade-down">
          <span class="w-6 h-px bg-sage-300 inline-block"></span>
          Start Today
          <span class="w-6 h-px bg-sage-300 inline-block"></span>
        </div>

        <h2
          id="cta-heading"
          class="font-display text-4xl md:text-5xl lg:text-6xl font-light text-white leading-tight mb-6"
          data-aos="fade-up"
          data-aos-delay="100"
        >
          Ready to find
          <em class="italic"> your</em> bridge?
        </h2>

        <p
          class="text-sage-100 text-lg leading-relaxed mb-10 max-w-lg mx-auto"
          data-aos="fade-up"
          data-aos-delay="160"
        >
          Join thousands of individuals, families, and organizations
          already building a more inclusive world with SpectrumBridge.
          No pressure. No rush. Just support.
        </p>

        <div
          class="flex flex-col sm:flex-row gap-4 justify-center"
          data-aos="fade-up"
          data-aos-delay="220"
        >
          <!-- Email form -->
          <form
            class="flex flex-col sm:flex-row gap-3 w-full max-w-md mx-auto"
            aria-label="Sign up form"
            novalidate
          >
            <label for="email-cta" class="sr-only">Your email address</label>
            <input
              id="email-cta"
              type="email"
              placeholder="Your email address"
              autocomplete="email"
              required
              class="flex-1 px-5 py-4 rounded-full bg-white/15 border border-white/30 text-white placeholder-sage-200
                focus:outline-none focus:ring-2 focus:ring-white/50 focus:bg-white/20
                transition-all duration-200 text-sm"
              aria-required="true"
            />
            <button
              type="submit"
              class="px-7 py-4 bg-white text-sage-600 font-semibold rounded-full
                hover:bg-sage-50 active:bg-sage-100
                transition-all duration-200 shadow-soft hover:shadow-soft-lg hover:-translate-y-0.5
                focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-sage-500
                text-sm whitespace-nowrap"
            >
              Get Early Access
            </button>
          </form>
        </div>

        <p class="text-sage-200 text-xs mt-5" data-aos="fade-up" data-aos-delay="280">
          Free forever for individuals. No credit card required.
          <a href="#" class="underline hover:text-white transition-colors">Privacy policy</a>.
        </p>

        <!-- Feature chips -->
        <div
          class="mt-10 flex flex-wrap justify-center gap-3"
          data-aos="fade-up"
          data-aos-delay="320"
          aria-label="Key features"
        >
          {[
            '✓ Sensory-friendly onboarding',
            '✓ AAC-compatible',
            '✓ Cancel anytime',
            '✓ WCAG 2.2 AA compliant',
          ].map(feat => (
            <span class="px-4 py-1.5 rounded-full bg-white/10 border border-white/20 text-sage-100 text-xs font-medium">
              {feat}
            </span>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
